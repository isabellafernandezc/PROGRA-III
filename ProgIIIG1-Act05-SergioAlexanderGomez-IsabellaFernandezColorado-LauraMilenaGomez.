% ------------------------- REGLAS -----------------------------------
% X es padre de Y si hay una conexion entre ellos
es_padre(X, Y):-
      padre(X, L),
      member(hijo(Y), L);
      padre(X,L),
      member(hija(Y), L).

% X es madre de Y si hay una conexion entre ellos
es_madre(X, Y):-
      madre(X, L),
      member(hijo(Y), L);
      madre(X, L),
      member(hija(Y), L).

% X es hijo de Y si Y es padre de X o madre de X.
es_hijo(X, Y):-
      es_padre(Y, X);
      es_madre(Y, X).
/*
X es abuelo de Y si existe un Z tal que:
1. Z es hijo de X
2. Z es padre o madre de Y
*/
es_abuelo(X, Y):-
      es_hijo(Z, X),
      (es_padre(Z, Y); es_madre(Z, Y)).

/*
X es hermano de Y si:
1. Comparte un mismo progenitor Z
2. X es diferente de Y
*/
es_hermano(X, Y):-
      es_hijo(X, Z),
      es_hijo(Y, Z),
      X \= Y.

/*
X es tío de Y si:
1. X es hermano de Z
2. Y es hijo de Z
*/
es_tio(X, Y):-
      es_hermano(X, Z),
      es_hijo(Y, Z).

/*
X es primo de Y si:
1. El padre/madre de X es A
2. El padre/madre de Y es B
3. A y B son hermanos
*/
es_primo(X, Y):-
      es_hijo(X, A),
      es_hijo(Y, B),
      es_hermano(A, B).

% X es nieto de Y si Y es abuelo de X.
es_nieto(X, Y):-
      es_abuelo(Y, X).

